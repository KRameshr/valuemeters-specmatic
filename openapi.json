  },
  "components": {
    "schemas": {
      "TransactionRequest": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": { "type": "number", "example": 100 }
        }
      },
      "TransferRequest": {
        "type": "object",
        "required": ["amount", "toAccountNumber"],
        "properties": {
          "amount": { "type": "number", "example": 100 },
          "toAccountNumber": { "type": "string", "example": "ACC000002" }
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": { "type": "string", "example": "Test User" },
          "email": { "type": "string", "example": "test@example.com" },
          "password": { "type": "string", "example": "password" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "example": "test@example.com" },
          "password": { "type": "string", "example": "password" }
        }
      },
      "ExpenseRequest": {
        "type": "object",
        "required": ["amount", "category"],
        "properties": {
          "amount": { "type": "number", "example": 50.0 },
          "category": { "type": "string", "example": "Food" }
        }
      },
      "BudgetRequest": {
        "type": "object",
        "required": ["dailyLimit", "weeklyLimit", "monthlyLimit"],
        "properties": {
          "dailyLimit": { "type": "number", "example": 100.0 },
          "weeklyLimit": { "type": "number", "example": 500.0 },
          "monthlyLimit": { "type": "number", "example": 2000.0 }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "status": { "type": "integer" },
          "error": { "type": "string" },
          "message": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    }
  }
}
